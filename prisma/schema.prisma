generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model User {
  id            String    @id @default(uuid())
  email         String    @unique
  passwordHash  String
  firstName     String
  lastName      String
  role          String    @default("CUSTOMER") // CUSTOMER, MERCHANT, ADMIN
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  customerProfile CustomerProfile?
  merchantProfile MerchantProfile?
}

model CustomerProfile {
  id        String   @id @default(uuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  activeContractId String? @unique
  contract         RentalContract? @relation(fields: [activeContractId], references: [id])

  transactions Transaction[]
}

model MerchantProfile {
  id              String   @id @default(uuid())
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  businessName    String
  businessType    String   // RESTAURANT, HOTEL, ACTIVITY, TOUR, SPA
  description     String?
  address         String
  city            String   @default("Paphos")
  latitude        Float?
  longitude       Float?
  imageUrl        String?

  discountRate    Float    @default(5.0) // Minimum 5%, max 25%
  status          String   @default("PENDING") // PENDING, APPROVED, REJECTED, SUSPENDED

  stripeAccountId String?  @unique
  platformFeeRate Float?   // Custom fee 2-15%, overrides global if set

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  transactions    Transaction[]
}

model RentalContract {
  id              String   @id @default(uuid())
  contractNumber  String   @unique
  agencyName      String
  startDate       DateTime
  endDate         DateTime
  vehicleClass    String?
  isValid         Boolean  @default(true)

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  customerProfile CustomerProfile?
}

model Transaction {
  id                String   @id @default(uuid())
  customerId        String
  customer          CustomerProfile @relation(fields: [customerId], references: [id])

  merchantId        String
  merchant          MerchantProfile @relation(fields: [merchantId], references: [id])

  originalAmount    Float
  discountRate      Float    // Percentage applied
  discountAmount    Float    // Absolute discount
  finalAmount       Float    // Amount paid by customer

  platformFeeRate   Float    // Fee percentage
  platformFee       Float    // Amount kept by platform
  merchantPayout    Float    // Amount sent to merchant

  status            String   @default("PENDING") // PENDING, COMPLETED, FAILED, REFUNDED
  stripePaymentId   String?  @unique
  qrToken           String?  @unique // The QR token used for this transaction

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model QrToken {
  id            String   @id @default(uuid())
  token         String   @unique
  customerId    String
  merchantId    String
  discountRate  Float
  expiresAt     DateTime
  used          Boolean  @default(false)
  createdAt     DateTime @default(now())
}

model PlatformSettings {
  id                  String   @id @default(uuid())
  defaultPlatformFee  Float    @default(10.0)
  minimumDiscountRate Float    @default(5.0)
  maximumDiscountRate Float    @default(25.0)
  updatedAt           DateTime @updatedAt
}
